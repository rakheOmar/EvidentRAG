# ── App ──────────────────────────────────────────
APP_NAME="EvidentRAG"
APP_ENV="development | production"
CLIENT_DIST_PATH="../client/dist"

# ── Logging ──────────────────────────────────────
LOG_LEVEL="DEBUG | INFO | WARNING | ERROR"
LOG_FORMAT="pretty | json"

# ── OpenTelemetry ────────────────────────────────
OTEL_ENABLED="true | false"
OTEL_SERVICE_NAME="evidentrag | server-scaffold"
OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector:4318"
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_EXPORTER_OTLP_PROTOCOL="grpc | http/protobuf"
OTEL_EXCLUDED_URLS="/health"

# ── LLM ──────────────────────────────────────────
LLM_API_BASE="your-llm-api-base"
LLM_API_KEY="your-llm-api-key"
GENERATION_MODEL="MODEL_NAME"
UTILITY_MODEL="MODEL_NAME"

# ── Embeddings ───────────────────────────────────
SEED_DEMO_DATA="true | false"
GEMINI_EMBEDDING_MODEL="gemini-embedding-2 | text-embedding-3-small"
GEMINI_EMBEDDING_DIMENSIONS="768 | 1536"

# ── Reranker (Cross-Encoder) ─────────────────────
RERANKER_API_BASE="https://api.cohere.com/v2"
RERANKER_API_KEY="your-reranker-api-key"
RERANKER_MODEL="rerank-english-v3.0 | rerank-v4.0-pro"

# ── PostgreSQL ───────────────────────────────────
POSTGRES_HOST="localhost | postgres"
POSTGRES_PORT="5432"
POSTGRES_USER="evidentrag"
POSTGRES_PASSWORD="evidentrag"
POSTGRES_DB="evidentrag"

# ── Qdrant (Vector Store) ────────────────────────
QDRANT_URL="http://localhost:6333 | http://qdrant:6333"
EVIDENCE_COLLECTION_NAME="evidentrag_evidence"

# ── Redis ────────────────────────────────────────
REDIS_URL="redis://localhost:6379 | redis://redis:6379"
