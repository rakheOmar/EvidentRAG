# ── App ──────────────────────────────────────────
APP_NAME="EvidentRAG"
APP_ENV="development | production"
CLIENT_DIST_PATH="../client/dist"

# ── Logging ──────────────────────────────────────
# Logs are always emitted as structured JSON.
LOG_LEVEL="INFO | ERROR"
SERVICE_VERSION="1.0.0"
COMMIT_SHA="git-commit-sha"
SERVICE_INSTANCE_ID="unique-process-or-container-id"
REGION="deployment-region"

# ── OpenTelemetry ────────────────────────────────
OTEL_ENABLED="true | false"
OTEL_SERVICE_NAME="evidentrag-server"
OTEL_EXPORTER_OTLP_PROTOCOL="grpc | http/protobuf"
# Use port 4317 for gRPC or 4318 for HTTP/protobuf.
OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector:4317"
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_EXPORTER_OTLP_INSECURE="true | false"
OTEL_TRACES_SAMPLER="parentbased_always_on | parentbased_traceidratio"
OTEL_TRACES_SAMPLER_ARG="1.0"
OTEL_RESOURCE_ATTRIBUTES="service.namespace=evidentrag"
OTEL_EXCLUDED_URLS="/health"

# ── LLM ──────────────────────────────────────────
LLM_API_BASE="your-llm-api-base"
LLM_API_KEY="your-llm-api-key"
GEMINI_API_KEY="your-gemini-api-key"
GENERATION_MODEL="MODEL_NAME"
UTILITY_MODEL="MODEL_NAME"

# ── Embeddings ───────────────────────────────────
SEED_DEMO_DATA="true | false"
GEMINI_EMBEDDING_MODEL="gemini-embedding-2 | text-embedding-3-small"
GEMINI_EMBEDDING_DIMENSIONS="768 | 1536"

# ── Reranker (Cross-Encoder) ─────────────────────
RERANKER_API_BASE="https://api.cohere.com/v2"
RERANKER_API_KEY="your-reranker-api-key"
RERANKER_MODEL="rerank-english-v3.0 | rerank-v4.0-pro"

# ── PostgreSQL ───────────────────────────────────
POSTGRES_HOST="localhost | postgres"
POSTGRES_PORT="5432"
POSTGRES_USER="evidentrag"
POSTGRES_PASSWORD="evidentrag"
POSTGRES_DB="evidentrag"

# ── Qdrant (Vector Store) ────────────────────────
QDRANT_URL="http://localhost:6333 | http://qdrant:6333"
EVIDENCE_COLLECTION_NAME="evidentrag_evidence"

# ── Redis ────────────────────────────────────────
REDIS_URL="redis://localhost:6379 | redis://redis:6379"

# Document ingestion
DOCUMENT_STORAGE_PATH="./data/documents | /app/data/documents"
MAX_DOCUMENT_UPLOAD_BYTES="26214400"
DOCUMENT_INGESTION_RETRY_ATTEMPTS="3"
DOCUMENT_AUDIT_RETENTION_DAYS="7"
