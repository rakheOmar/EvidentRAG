# App
APP_NAME="EvidentRAG"
APP_ENV="development"
CLIENT_DIST_PATH="../client/dist"

# Logging
LOG_LEVEL="INFO"
SERVICE_VERSION=""
COMMIT_SHA=""
SERVICE_INSTANCE_ID=""
REGION=""

# OpenTelemetry
OTEL_ENABLED="false"
OTEL_SERVICE_NAME="evidentrag-server"
OTEL_EXPORTER_OTLP_PROTOCOL="grpc"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_EXPORTER_OTLP_INSECURE="true"
OTEL_TRACES_SAMPLER="parentbased_always_on"
OTEL_TRACES_SAMPLER_ARG="1.0"
OTEL_RESOURCE_ATTRIBUTES="service.namespace=evidentrag"
OTEL_EXCLUDED_URLS="/health"

# Language Models
LLM_API_BASE="http://localhost:8081/v1"
LLM_API_KEY=""
GENERATION_MODEL="gemini-2.5-pro"
UTILITY_MODEL="gemini-2.5-flash"

# Embeddings
GEMINI_API_BASE="https://generativelanguage.googleapis.com"
GEMINI_API_KEY=""
GEMINI_EMBEDDING_MODEL="gemini-embedding-2"
GEMINI_EMBEDDING_DIMENSIONS="768"
EMBEDDING_BATCH_SIZE="64"

# Reranking
RERANKER_API_BASE="https://api.cohere.com/v2"
RERANKER_API_KEY=""
RERANKER_MODEL="rerank-english-v3.0"

# Document Ingestion
SEED_DEMO_DATA="false"
DOCUMENT_STORAGE_PATH="./data/documents"
MAX_DOCUMENT_UPLOAD_BYTES="26214400"
DOCUMENT_INGESTION_RETRY_ATTEMPTS="3"
DOCUMENT_INGESTION_TIMEOUT_SECONDS="900"
DOCUMENT_AUDIT_RETENTION_DAYS="7"

# AI Scheduling
AI_RETRY_WINDOW_SECONDS="60"

## Generation LLM
LLM_GENERATION_REQUESTS_PER_MINUTE="20"
LLM_GENERATION_CONCURRENCY="2"

## Utility LLM
LLM_UTILITY_REQUESTS_PER_MINUTE="60"
LLM_UTILITY_CONCURRENCY="4"

## Embeddings
EMBEDDING_REQUESTS_PER_MINUTE="60"
EMBEDDING_CONCURRENCY="4"

## Reranker
RERANK_REQUESTS_PER_MINUTE="10"
RERANK_CONCURRENCY="2"

# PostgreSQL
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="evidentrag"
POSTGRES_PASSWORD="evidentrag"
POSTGRES_DB="evidentrag"

# Qdrant
QDRANT_URL="http://localhost:6333"
EVIDENCE_COLLECTION_NAME="evidentrag_evidence"

# Redis
REDIS_URL="redis://localhost:6379/0"
